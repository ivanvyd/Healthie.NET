@* Healthie.NET dashboard -- Pulse Monitor. *@
@implements IAsyncDisposable
@using Healthie.Abstractions.Extensions
@using Healthie.Dashboard.Components
@inject IHealthieDashboardService DashboardService
@inject HealthieUIOptions Options
@inject HealthieThemeState ThemeState

<PageTitle>@Options.DashboardTitle</PageTitle>
<HeadContent>
    <link href="_content/Healthie.NET.Dashboard/healthie.css" rel="stylesheet" />
</HeadContent>

<div class="healthie-dashboard" data-hpm="@(_isDarkMode ? "dark" : "light")">

    <header class="hpm-header">
        <div class="hpm-header-inner">
            <div class="hpm-brand @StatusClass(_overall)">
                <span class="hpm-led" aria-hidden="true"></span>
                <span class="hpm-wordmark">@WordMark</span>
            </div>
            <span class="hpm-overall @StatusClass(_overall)" role="status">@OverallLabel</span>

            <div class="hpm-spacer"></div>

            <span class="hpm-clock">@_now.ToString("HH:mm:ss") LOCAL</span>

            <div class="hpm-search">
                <span class="hpm-search-icon" aria-hidden="true">@HealthieIcons.Search</span>
                <input type="text" placeholder="Search" aria-label="Search checkers"
                       value="@_searchFilter" @oninput="OnSearchInput" />
            </div>

            <div class="hpm-actions">
                <button type="button" class="hpm-btn" title="Run all checks now" @onclick="TriggerAllAsync">RUN ALL</button>
                <button type="button" class="hpm-btn hpm-btn--icon hpm-btn--start" title="Start all checkers" aria-label="Start all checkers" @onclick="StartAllAsync">▶</button>
                <button type="button" class="hpm-btn hpm-btn--icon hpm-btn--stop" title="Pause all checkers" aria-label="Pause all checkers" @onclick="StopAllAsync">❚❚</button>
                @if (Options.EnableDarkModeToggle)
                {
                    <button type="button" class="hpm-btn hpm-btn--icon hpm-btn--theme"
                            title="@(_isDarkMode ? "Switch to light mode" : "Switch to dark mode")"
                            @onclick="ToggleThemeAsync">@(_isDarkMode ? "☀" : "☾")</button>
                }
            </div>
        </div>

        <div class="hpm-trace-wrap">
            <div class="hpm-trace">
                @* One tile of the trace, repeated across the width and scrolled by exactly one tile. *@
                <svg preserveAspectRatio="none" viewBox="0 0 1760 64" aria-hidden="true" focusable="false">
                    <defs>
                        <pattern id="@_traceId" x="0" y="0" width="220" height="64" patternUnits="userSpaceOnUse">
                            <polyline points="0,40 58,40 70,40 78,16 88,56 97,32 104,40 148,40 158,31 168,40 220,40"
                                      fill="none" stroke="@TraceColor" stroke-width="1.8"
                                      stroke-linejoin="round" stroke-linecap="round" />
                        </pattern>
                    </defs>
                    <rect x="0" y="0" width="1760" height="64" fill="url(#@_traceId)" />
                </svg>
                <div class="hpm-trace-label">AGGREGATE PULSE · @ChecksPerMinute CHECKS/MIN</div>
            </div>
        </div>
    </header>

    <div class="hpm-body">
        <div class="hpm-list">
            <div class="hpm-list-head" aria-hidden="true">
                <span></span>
                <span>CHECKER</span>
                <span>RATE</span>
                <span>PULSE · LAST @HistoryWindow</span>
                <span class="hpm-right">LAST RUN</span>
                <span></span>
            </div>

            @if (_isLoading)
            {
                @for (var i = 0; i < 5; i++)
                {
                    <div class="hpm-skeleton"></div>
                }
            }
            else if (_filtered.Count == 0)
            {
                <div class="hpm-empty">
                    @if (_states.Count == 0)
                    {
                        <span>No pulse checkers registered. Add a class deriving from <code>PulseChecker</code> to get started.</span>
                    }
                    else
                    {
                        <span>No checkers match the search.</span>
                    }
                </div>
            }
            else
            {
                var delay = 0;

                foreach (var (name, state) in _filtered)
                {
                    var isSelected = name == _selected;
                    var status = StatusOf(state);
                    var history = HistoryOf(name);

                    <div class="hpm-row @StatusClass(status) @(isSelected ? "hpm-row--selected" : "") @(state.IsActive ? "" : "hpm-row--paused")"
                         style="animation-delay: @(delay)ms"
                         role="button" tabindex="0"
                         aria-pressed="@(isSelected ? "true" : "false")"
                         @onclick="@(() => _selected = name)"
                         @onkeydown="@(e => OnRowKeyDown(e, name))">

                        <span class="hpm-led @(state.IsActive ? "" : "hpm-led--steady") @(status == Status.Critical ? "hpm-led--urgent" : "")"
                              aria-hidden="true"></span>

                        <div class="hpm-row-name">
                            <div class="hpm-row-title">@DisplayNameOf(name)</div>
                            <div class="hpm-row-sub">@StatusWord(state) · @ShortTypeName(name)</div>
                        </div>

                        <div class="hpm-rate-cell">
                            <span class="hpm-rate @(state.IsActive ? "" : "hpm-rate--paused")">@RatePerMinute(state)</span>
                            <span class="hpm-rate-unit">per min</span>
                        </div>

                        @if (history.Count == 0)
                        {
                            <span class="hpm-blips-empty">no runs yet</span>
                        }
                        else
                        {
                            <div class="hpm-blips" title="@history.Count recent run(s), oldest first">
                                @foreach (var entry in history)
                                {
                                    <span class="hpm-blip @BlipClass(entry.Health) @StatusClass(StatusOf(entry.Health))"
                                          title="@entry.Health at @entry.ExecutedAt.ToLocalTime().ToString("HH:mm:ss")"></span>
                                }
                            </div>
                        }

                        <span class="hpm-time">@Relative(state.LastExecutionDateTime)</span>

                        <div class="hpm-row-actions">
                            <button type="button" class="hpm-icon-btn hpm-icon-btn--run" title="Run now"
                                    aria-label="Run @DisplayNameOf(name) now"
                                    @onclick="@(() => TriggerCheckerAsync(name))" @onclick:stopPropagation="true">
                                @HealthieIcons.Zap
                            </button>
                            <button type="button" class="hpm-icon-btn" title="@(state.IsActive ? "Pause" : "Start")"
                                    aria-label="@(state.IsActive ? "Pause" : "Start") @DisplayNameOf(name)"
                                    @onclick="@(() => ToggleCheckerAsync(name, state.IsActive))" @onclick:stopPropagation="true">
                                @(state.IsActive ? HealthieIcons.Pause : HealthieIcons.Play)
                            </button>
                        </div>
                    </div>

                    delay += 30;
                }
            }
        </div>

        <aside class="hpm-side">
            @if (_selectedState is { } selected)
            {
                var selectedStatus = StatusOf(selected);

                <section class="hpm-panel @StatusClass(selectedStatus)">
                    <div class="hpm-panel-head">
                        <div class="hpm-eyebrow">SELECTED CHECKER</div>
                        <div class="hpm-sel-title">
                            <span class="hpm-sel-name">@DisplayNameOf(_selected!)</span>
                            <span class="hpm-tag">@StatusWord(selected)</span>
                        </div>
                        <div class="hpm-sel-fullname">@_selected</div>
                    </div>

                    <div class="hpm-panel-body">
                        <div class="hpm-stats">
                            <div class="hpm-stat">
                                <div class="hpm-stat-label">UPTIME</div>
                                <div class="hpm-stat-value" style="color: @UptimeColor(_selected!)">@Uptime(_selected!)</div>
                            </div>
                            <div class="hpm-stat">
                                <div class="hpm-stat-label">FAILS</div>
                                <div class="hpm-stat-value" style="color: @(selected.ConsecutiveFailureCount > 0 ? "var(--hpm-crit)" : "var(--hpm-text)")">
                                    @FailuresLabel(selected)
                                </div>
                            </div>
                            <div class="hpm-stat">
                                <div class="hpm-stat-label">STATE</div>
                                <div class="hpm-stat-value" style="color: @(selected.IsActive ? "var(--hpm-ok)" : "var(--hpm-faint)")">
                                    @(selected.IsActive ? "LIVE" : "IDLE")
                                </div>
                            </div>
                        </div>

                        <div class="hpm-message">@(string.IsNullOrWhiteSpace(selected.LastResult?.Message) ? "No result recorded yet." : selected.LastResult!.Message)</div>

                        <div class="hpm-sel-actions">
                            <button type="button" class="hpm-sel-btn hpm-sel-btn--primary" @onclick="@(() => TriggerCheckerAsync(_selected!))">RUN NOW</button>
                            <button type="button" class="hpm-sel-btn" @onclick="@(() => ToggleCheckerAsync(_selected!, selected.IsActive))">@(selected.IsActive ? "PAUSE" : "START")</button>
                            <button type="button" class="hpm-sel-btn hpm-sel-btn--reset" @onclick="@(() => ResetCheckerAsync(_selected!))">RESET</button>
                        </div>

                        <div class="hpm-fields">
                            <div class="hpm-field">
                                <label for="hpm-interval">INTERVAL</label>
                                <select id="hpm-interval" value="@selected.Interval" @onchange="OnIntervalChanged">
                                    @foreach (var interval in Intervals)
                                    {
                                        <option value="@interval" selected="@(interval == selected.Interval)">@Describe(interval)</option>
                                    }
                                </select>
                            </div>
                            <div class="hpm-field">
                                <label for="hpm-threshold">FAIL THRESHOLD</label>
                                <input id="hpm-threshold" type="number" min="0" value="@selected.UnhealthyThreshold" @onchange="OnThresholdChanged" />
                            </div>
                        </div>
                    </div>
                </section>
            }

            <section class="hpm-panel">
                <div class="hpm-log-head">
                    <span class="hpm-eyebrow" style="margin: 0;">EVENT LOG</span>
                    <div class="hpm-spacer"></div>
                    <span class="hpm-log-led" aria-hidden="true"></span>
                </div>
                <div class="hpm-log-body">
                    @if (_events.Count == 0)
                    {
                        <div class="hpm-log-empty">Quiet so far. Events appear as checks change state.</div>
                    }
                    else
                    {
                        @foreach (var entry in _events)
                        {
                            <div class="hpm-event @StatusClass(entry.Status)">
                                <span class="hpm-event-time">@entry.At.ToString("HH:mm:ss")</span>
                                <span class="hpm-event-tag">[@entry.Tag]</span>
                                <span class="hpm-event-text" title="@entry.Text">@entry.Text</span>
                            </div>
                        }
                    }
                </div>
            </section>
        </aside>
    </div>
</div>
